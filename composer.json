{
    "name": "wizballesy/librenms-oxidized-history",
    "description": "LibreNMS package for viewing historical Oxidized configuration history through an external Oxidized History API service.",
    "type": "package",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Tom Stian Bjerk"
        }
    ],
    "require": {
        "php": "^8.2",
        "librenms/plugin-interfaces": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "WizballEsy\\LibreNmsOxidizedHistory\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "WizballEsy\\LibreNmsOxidizedHistory\\LibreNmsOxidizedHistoryServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
